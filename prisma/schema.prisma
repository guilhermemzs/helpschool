generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  COORDINATOR
  SECRETARY
}

enum ClassStatus {
  ACTIVE
  PAUSED
  CANCELLED
  FINISHED
}

enum ClassType {
  FIXED
  FLEXIBLE
}

enum Modality {
  ONLINE
  PRESENCIAL
  DOMICILIO
  HIBRIDA
}

enum LessonStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum TeacherStatus {
  ACTIVE
  INACTIVE
  VACATION
  UNAVAILABLE
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(SECRETARY)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Class {
  id               String      @id @default(cuid())
  code             String      @unique
  studentNames     String
  classType        ClassType   @default(FIXED)
  groupType        String      @default("Individual") // "Individual" | "Grupo"
  modality         Modality    @default(ONLINE)
  level            String      @default("A1")
  ageGroup         String?
  lessonsPerWeek   Int         @default(2)
  allowedTeachers  String?     // JSON array of teacher IDs allowed
  restrictedTeachers String?   // JSON array of teacher IDs restricted
  notes            String?
  status           ClassStatus @default(ACTIVE)
  fixedLessons     FixedLesson[]
  dailyLessons     DailyLesson[]
  flexibleSchedules FlexibleSchedule[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@map("classes")
}

model Teacher {
  id           String        @id @default(cuid())
  name         String
  status       TeacherStatus @default(ACTIVE)
  type         String        @default("FLEXIBLE") // FIXED | FLEXIBLE
  modalities   String        @default("ONLINE")   // JSON array: ["ONLINE","PRESENCIAL"]
  languages    String        @default("Inglês")   // "Inglês", "Espanhol", "Inglês,Espanhol"
  specialty    String?
  needsConfirm Boolean       @default(true)
  notes        String?
  restrictions String?
  availability TeacherAvailability[]
  dailyLessons DailyLesson[]
  flexibleSchedules FlexibleSchedule[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("teachers")
}

model TeacherAvailability {
  id         String   @id @default(cuid())
  teacherId  String
  teacher    Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  weekday    String   // "Segunda","Terça","Quarta","Quinta","Sexta","Sábado"
  startTime  String?  // "06:00"
  endTime    String?  // "22:00"

  @@map("teacher_availability")
}

// Aulas fixas — grade semanal permanente
model FixedLesson {
  id         String   @id @default(cuid())
  classId    String
  class      Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  weekday    String   // "Segunda","Terça","Quarta","Quinta","Sexta","Sábado"
  startTime  String   // "07:00"
  endTime    String   // "08:00"
  modality   Modality @default(ONLINE)
  notes      String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("fixed_lessons")
}

// Escala diária — cópia operacional do dia
model DailyLesson {
  id           String       @id @default(cuid())
  date         DateTime     // data específica ex: 2026-05-26
  weekday      String
  classId      String
  class        Class        @relation(fields: [classId], references: [id])
  teacherId    String?
  teacher      Teacher?     @relation(fields: [teacherId], references: [id])
  startTime    String
  endTime      String
  modality     Modality     @default(ONLINE)
  status       LessonStatus @default(PENDING)
  isFromFixed  Boolean      @default(false) // veio da grade fixa?
  notes        String?
  cancelReason String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("daily_lessons")
}

// Agendamento de aulas flexíveis
model FlexibleSchedule {
  id          String       @id @default(cuid())
  classId     String
  class       Class        @relation(fields: [classId], references: [id])
  teacherId   String?
  teacher     Teacher?     @relation(fields: [teacherId], references: [id])
  date        DateTime
  weekday     String
  startTime   String
  endTime     String
  modality    Modality     @default(ONLINE)
  status      LessonStatus @default(PENDING)
  notes       String?
  weekStart   DateTime     // início da semana (segunda) para controle semanal
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("flexible_schedules")
}
